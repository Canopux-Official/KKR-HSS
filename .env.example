# Site URL (required for canonical URLs, sitemap, and Open Graph)
NEXT_PUBLIC_SITE_URL=https://kkrwomens.edu.in

# Google Analytics 4 measurement ID (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Form submission endpoints (optional — connect when backend is ready)
# NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
# NEXT_PUBLIC_ADMISSION_FORM_ENDPOINT=

# CMS integration (optional — for future headless CMS)
# CMS_API_URL=
# CMS_API_TOKEN=

# Maintenance mode (optional — redirect all traffic when true)
# NEXT_PUBLIC_MAINTENANCE_MODE=false
