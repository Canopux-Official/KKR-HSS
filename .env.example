# Site URL (required for canonical URLs, sitemap, Open Graph, and JSON-LD)
NEXT_PUBLIC_SITE_URL=https://kkrwomens.edu.in

# --- Analytics & search console (optional — enable in production) ---

# Google Analytics 4 measurement ID (used when GTM is not set)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager container ID (takes precedence over standalone GA4)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Search Console site verification meta content value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token

# Bing Webmaster Tools verification
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-verification-token

# Yandex Webmaster verification (optional)
# NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=your-verification-token

# Microsoft Clarity project ID
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id

# Meta (Facebook) Pixel ID (optional)
# NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id

# --- Forms (optional — connect when backend is ready) ---
# NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
# NEXT_PUBLIC_ADMISSION_FORM_ENDPOINT=

# --- CMS integration (optional — for future headless CMS) ---
# CMS_API_URL=
# CMS_API_TOKEN=

# --- Maintenance mode (optional — redirect all traffic when true) ---
# NEXT_PUBLIC_MAINTENANCE_MODE=false
