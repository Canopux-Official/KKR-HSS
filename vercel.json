{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/enquiry/route.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.kkrwomens.edu.in"
        }
      ],
      "destination": "https://kkrwomens.edu.in/:path*",
      "permanent": true
    }
  ]
}
